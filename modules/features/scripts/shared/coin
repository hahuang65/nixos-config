class SuggestInput(Input):
    """Input that accepts suggestions with Tab.

    If suggestion is in format "MatchedName (CanonicalName)", extracts
    and uses just the canonical name.
    """

    BINDINGS: list[tuple[str, str, str]] = [
        ("tab", "accept_suggestion", "Accept suggestion"),
    ]

    def action_accept_suggestion(self) -> None:
        if self._suggestion:
            suggestion = self._suggestion
            # Extract canonical name from "MatchedName (CanonicalName)" format
            if " (" in suggestion and suggestion.endswith(")"):
                suggestion = suggestion.split(" (")[1][:-1]
            self.value = suggestion
            self.cursor_position = len(self.value)


