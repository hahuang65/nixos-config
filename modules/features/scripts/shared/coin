class NameRegistry:
    """Union-find structure to group company names/aliases globally."""

    def __init__(self, txns: list["Transaction"]):
        self._parent: dict[str, str] = {}
        self._txns_by_name: dict[str, list["Transaction"]] = {}
        self._primary_names: set[str] = set()

        for t in txns:
            # Track primary names (from the Name column)
            self._primary_names.add(t.names[0])

            for name in t.names:
                self._txns_by_name.setdefault(name, []).append(t)
                if name not in self._parent:
                    self._parent[name] = name

            # Union all names in this transaction together
            first = t.names[0]
            for name in t.names[1:]:
                self._union(first, name)

    def _find(self, name: str) -> str:
        if self._parent[name] != name:
            self._parent[name] = self._find(self._parent[name])
        return self._parent[name]

    def _union(self, a: str, b: str) -> None:
        ra, rb = self._find(a), self._find(b)
        if ra != rb:
            self._parent[rb] = ra

    def get_all_names(self, name: str) -> set[str]:
        """Get all names/aliases for the company that includes this name."""
        if name not in self._parent:
            return set()
        root = self._find(name)
        return {n for n in self._parent if self._find(n) == root}

    def get_transactions(self, name: str) -> list["Transaction"]:
        """Get all transactions for the company that includes this name."""
        all_names = self.get_all_names(name)
        seen: set[int] = set()
        result: list["Transaction"] = []
        for n in all_names:
            for t in self._txns_by_name.get(n, []):
                if id(t) not in seen:
                    seen.add(id(t))
                    result.append(t)
        return result

    def get_canonical_name(self, name: str) -> str:
        """Get the canonical name (from Name column) for a company."""
        all_names = self.get_all_names(name)
        if not all_names:
            return name
        # Find the primary name (from Name column) in this group
        primary_in_group = all_names & self._primary_names
        if primary_in_group:
            # If multiple primary names, return the first alphabetically
            return min(primary_in_group)
        return name

    def fuzzy_match(
        self, query: str, threshold: int = 60
    ) -> tuple[str, str, int] | None:
        """Find the best fuzzy match for a query.

        Returns (matched_name, canonical_name, score) or None if no match above threshold.
        Tries prefix match first (score 100), then falls back to fuzzy match.
        """
        results = self.fuzzy_match_all(query, threshold)
        return results[0] if results else None

    def fuzzy_match_all(
        self, query: str, threshold: int = 60
    ) -> list[tuple[str, str, int]]:
        """Find all fuzzy matches for a query, grouped by company.

        Returns list of (matched_name, canonical_name, score) sorted by score descending.
        Only includes companies with score >= threshold.
        """
        if not query:
            return []

        query_lower = query.lower()
        seen_roots: set[str] = set()
        results: list[tuple[str, str, int]] = []

        for name in self._parent:
            root = self._find(name)
            if root in seen_roots:
                continue

            # Find best matching name across all names in this company
            all_names = self.get_all_names(name)
            best_name = None
            best_score = 0
            for n in all_names:
                if n.lower().startswith(query_lower):
                    best_name = n
                    best_score = 100
                    break
                score = fuzz.partial_ratio(query_lower, n.lower())
                if score > best_score:
                    best_name = n
                    best_score = score

            if best_score >= threshold and best_name:
                seen_roots.add(root)
                canonical = self.get_canonical_name(name)
                results.append((best_name, canonical, best_score))

        results.sort(key=lambda x: x[2], reverse=True)
        return results


class NameSuggester(Suggester):
    """Suggester that uses fuzzy matching to find canonical company names.

    Returns suggestions in format "MatchedName (CanonicalName)" or just
    "MatchedName" if they're the same.
    """

    def __init__(self, registry: NameRegistry, threshold: int = 50):
        super().__init__(use_cache=False, case_sensitive=False)
        self._registry = registry
        self._threshold = threshold

    async def get_suggestion(self, value: str) -> str | None:
        if not self._registry:
            return None

        match = self._registry.fuzzy_match(value, self._threshold)
        if not match:
            return None

        matched_name, canonical, _ = match
        if matched_name == canonical:
            return matched_name
        return f"{matched_name} ({canonical})"


class Transaction:
    @staticmethod
    def _parse_date(value) -> datetime:
        for fmt in ("%m/%d/%Y", "%m/%d/%y"):
            try:
                return datetime.strptime(value, fmt).date()
            except ValueError:
                continue
        raise ValueError(f"Unable to parse date: {value!r}")

    @staticmethod
    def _parse_amount(value: str) -> float:
        value = value.strip()
        negative = value.startswith("-") or (
            value.startswith("(") and value.endswith(")")
        )
        value = (
            value.replace("$", "")
            .replace(",", "")
            .replace("(", "")
            .replace(")", "")
            .replace("-", "")
        )
        amount = float(value) if value else 0.0
        return -amount if negative else amount

    def __init__(self, row):
        self.names: list[str] = [row[NAME_COL].strip()] + [
            v.strip() for v in row[AKA_COL].split(",") if v.strip()
        ]
        self.date: datetime = self._parse_date(row[DATE_COL])
        self.fund: str = row[FUND_COL]
        self.amount: float = self._parse_amount(row[AMT_COL])
        self.follow_on: datetime = row[FOLLOW_ON_COL].strip().upper() == "TRUE"
        self.dist_date: datetime | None = (
            self._parse_date(row[DIST_DATE_COL]) if row[DIST_DATE_COL].strip() else None
        )
        self.dist_type: str = (
            row[DIST_TYPE_COL].strip() if row[DIST_TYPE_COL].strip() else ""
        )

    @staticmethod
    def _is_ssh_path(filepath: str) -> bool:
        return ":" in filepath

    @classmethod
    def from_csv(cls, filepath) -> list[Self]:
        try:
            if cls._is_ssh_path(filepath):
                host, remote_path = filepath.split(":", 1)
                result = subprocess.run(
                    ["ssh", host, "cat", remote_path],
                    capture_output=True,
                    text=True,
                )
                if result.returncode != 0:
                    console.print(f"[red]Error:[/red] {result.stderr.strip()}")
                    sys.exit(1)
                content = result.stdout
                if content.startswith("\ufeff"):
                    content = content[1:]
            else:
                with open(filepath, "r", encoding="utf-8-sig") as f:
                    content = f.read()
        except FileNotFoundError:
            console.print(f"[red]Error:[/red] file not found: {filepath}")
            sys.exit(1)
        except OSError as e:
            console.print(f"[red]Error:[/red] failed to open file: {e}")
            sys.exit(1)
        reader = csv.DictReader(io.StringIO(content))
        rows = list(reader)
        if not rows:
            console.print("[red]Error:[/red] CSV file is empty or has no data rows.")
            sys.exit(1)
        return [cls(row) for row in rows]


@dataclass
class Formula:
    flag: str
    description: str
    fn: Callable[..., Table]
    extra_args: list[str] = field(default_factory=list)
    optional_args: dict[str, dict] = field(default_factory=dict)


FORMULAS: list[Formula] = [
