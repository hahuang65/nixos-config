            self.action_confirm()


class DownloadScreen(Screen):
    """Screen for downloading ROMs"""

    def __init__(self, selected_roms: List[tuple], sd_card: Path):
        super().__init__()
        self.selected_roms = selected_roms
        self.sd_card = sd_card

    def compose(self) -> ComposeResult:
        yield Header()
        yield Container(
            Static("Downloading ROMs...", id="status"),
            ProgressBar(total=len(self.selected_roms), show_eta=True, id="progress"),
            VerticalScroll(id="log"),
            Button("Done", id="done-btn", variant="success", disabled=True),
            id="main-container",
        )
        yield Footer()

    def on_mount(self):
        """Start download when screen is mounted"""
        self.download_roms()

    def download_roms(self):
        """Download all selected ROMs"""
        status = self.query_one("#status", Static)
        progress = self.query_one("#progress", ProgressBar)
        log = self.query_one("#log", VerticalScroll)

        # Setup SFTP connection
        log.mount(Static("[cyan]→[/cyan] Connecting to server via SFTP..."))
        sftp = setup_sftp()

        if not sftp:
            log.mount(Static("[red]✗[/red] SFTP connection failed"))
            status.update("Failed to connect to server")
            self.query_one("#done-btn", Button).disabled = False
            return

        log.mount(Static("[green]✓[/green] Connected"))

        success_count = 0
        artwork_count = 0
        skipped_count = 0
        skipped_platforms = set()

        for i, (platform, rom) in enumerate(self.selected_roms):
            rom_name = rom.get("name") or rom.get("fs_name", f"ROM #{rom['id']}")
            status.update(
                f"Downloading {rom_name}... ({i + 1}/{len(self.selected_roms)})"
            )

            # Check if platform has a mapping
            slug = platform.get("slug", "")
            emulator_name = PLATFORM_MAPPING.get(slug, "")

            if not emulator_name:
                # Skip this ROM - no mapping found
                log.mount(Static(f"[yellow]⊘[/yellow] {rom_name}"))
                log.mount(
                    Static(
                        f"  [yellow]⚠[/yellow] Skipped - no mapping for platform '{slug}'"
                    )
                )
                skipped_count += 1
                skipped_platforms.add(platform.get("name", slug))
                progress.advance(1)
                continue

            # Find the full directory name on SD card or create new one
            platform_dir_name = find_directory_by_emulator(self.sd_card, emulator_name)
            if not platform_dir_name:
                # Create new directory with pattern: Platform Name (EMULATOR)
                platform_name = platform.get("name", "Unknown")
                platform_dir_name = f"{platform_name} ({emulator_name})"

            platform_dir = self.sd_card / "Roms" / platform_dir_name
            media_dir = platform_dir / ".media"

            fs_name = rom.get("fs_name")
            fs_extension = rom.get("fs_extension", "bin")
            rom_filename = fs_name or f"{rom_name}.{fs_extension}"
            dest_rom = platform_dir / rom_filename

            # Download ROM
            log.mount(Static(f"[cyan]→[/cyan] {rom_name}"))
            rom_success, rom_error = download_rom(rom, dest_rom, sftp)
            if rom_success:
                log.mount(Static(f"  [green]✓[/green] ROM saved to: {dest_rom}"))
                success_count += 1

                # Download artwork
                artwork_name = Path(rom_filename).stem + ".png"
                dest_artwork = media_dir / artwork_name

                if download_artwork(rom, dest_artwork, sftp):
                    log.mount(
                        Static(f"  [green]✓[/green] Artwork saved to: {dest_artwork}")
                    )
                    artwork_count += 1
                else:
                    log.mount(Static("  [yellow]⚠[/yellow] No artwork"))
            else:
                log.mount(Static(f"  [red]✗[/red] Failed: {rom_error}"))

            progress.advance(1)

        # Close SFTP connection
        if sftp:
            sftp.close()
            log.mount(Static("[cyan]→[/cyan] Disconnected from server"))

        status.update(
            f"Complete! {success_count}/{len(self.selected_roms)} ROMs downloaded"
        )
        log.mount(
            Static(
                f"\n[bold green]✓ Downloaded {success_count} ROMs and {artwork_count} artworks[/bold green]"
            )
        )
        log.mount(Static(f"[bold]Location:[/bold] {self.sd_card / 'Roms'}"))

        # Show skipped ROMs if any
        if skipped_count > 0:
            log.mount(Static(""))
            log.mount(
                Static(
                    f"[bold yellow]⚠ Skipped {skipped_count} ROMs - no platform mapping found[/bold yellow]"
                )
            )
            log.mount(
                Static(
                    f"[yellow]Unmapped platforms:[/yellow] {', '.join(sorted(skipped_platforms))}"
                )
            )
            log.mount(
                Static(
                    "[yellow]Add mappings to PLATFORM_MAPPING in the script to download these ROMs.[/yellow]"
                )
            )

        # Enable done button
        self.query_one("#done-btn", Button).disabled = False

    def on_button_pressed(self, event: Button.Pressed):
        if event.button.id == "done-btn":
            self.app.exit()


